rules_version = '2';

// 한국 대학 입시 서비스 — Firestore 보안 규칙 초안
//
// 원칙:
//   1. 마스터 데이터(대학·학과·모집요강)는 read 공개, write는 운영자만
//      → 비로그인 SEO·랜딩에서 호출 가능해야 함
//   2. 사용자 데이터(specs/intent)는 본인만 read/write
//   3. 결제 도큐먼트는 클라 write 절대 금지 → Admin SDK 트랜잭션만
//   4. paymentKey 등 토스 자격증명은 클라 read 차단
//   5. 합격사례(admissionResults)는 verified=true만 노출
//   6. 기본 deny — 명시적으로 allow한 경로만 통과
//
// 운영자 식별:
//   admins/{uid} 도큐먼트 존재 + active=true
//   콘솔에서 직접 관리 (write 차단)

service cloud.firestore {
  match /databases/{database}/documents {

    /* ═══════════════════════════════════════════════════════════════════
       Helpers
       ═══════════════════════════════════════════════════════════════════ */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isMaster() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    /* ═══════════════════════════════════════════════════════════════════
       universities — 대학 마스터
       read 공개 (SEO·비로그인 페이지 지원), write 운영자만
       ═══════════════════════════════════════════════════════════════════ */

    match /universities/{universityId} {
      allow read: if true;
      allow write: if isMaster();

      // 학과 (서브컬렉션)
      match /departments/{departmentId} {
        allow read: if true;
        allow write: if isMaster();

        // 연도별 모집요강 (서브-서브컬렉션)
        match /admissions/{year} {
          allow read: if true;
          allow write: if isMaster();
        }
      }
    }

    /* ═══════════════════════════════════════════════════════════════════
       admissionResults — 익명 합격사례
       verified=true 인 도큐먼트만 read 허용
       자가보고 create는 verified=false 강제 (운영자가 검증 후 활성화)
       ═══════════════════════════════════════════════════════════════════ */

    match /admissionResults/{resultId} {
      allow read: if resource.data.verified == true || isMaster();

      allow create: if isSignedIn()
                    && request.resource.data.source == "self_report"
                    && request.resource.data.verified == false
                    && request.resource.data.confidence <= 0.5;

      allow update, delete: if isMaster();
    }

    /* ═══════════════════════════════════════════════════════════════════
       admissionSampleStats — 합격사례 표본 집계 (학과·전형·연도별)
       클라이언트는 read만 (sample-gate에서 표본 부족 판정 시 즉시 조회).
       write는 admissionResults trigger(Cloud Function) 또는 운영자.
       ═══════════════════════════════════════════════════════════════════ */

    match /admissionSampleStats/{statsId} {
      allow read: if true;
      allow write: if isMaster();
    }

    /* ═══════════════════════════════════════════════════════════════════
       users — 사용자 도큐먼트
       본인 또는 운영자만 read. write는 본인만 (entitlements 제외).
       ═══════════════════════════════════════════════════════════════════ */

    match /users/{uid} {
      allow read: if isOwner(uid) || isMaster();

      // 본인이 자기 도큐먼트 write 가능. 단, plan/entitlement 관련 필드는 차단.
      // (결제 승인 트랜잭션에서만 변경되어야 함)
      allow create, update: if isOwner(uid)
                            && !request.resource.data.diff(resource.data).affectedKeys()
                                  .hasAny(["plan", "planBilling", "currentPlan", "lastPayment", "planSource"]);
      allow delete: if false; // 탈퇴는 별도 API 경유 (Admin SDK)

      /* specs — 학년별 입력 스냅샷. 본인만.
         intent 형태 검증(가/나/다군 단일 슬롯, 수시 6장 한도)을 rules에서 강제.
         의미 검증(같은 학과 중복 등록 등 비즈니스 룰)은 API 라우트
         (/api/intent/validate)의 트랜잭션 가드에서 수행 — rules는 형태만. */
      match /specs/{specId} {
        function validIntent(intent) {
          // intent 자체가 없거나 null이면 OK (스펙 입력 중)
          return intent == null || (
            // susi: 0~6개 배열
            (intent.susi is list && intent.susi.size() <= 6) &&
            // jeongsi: 객체 — ga/na/da 키만 허용. 각 값은 단일 슬롯(map) 또는 미존재.
            (intent.jeongsi is map) &&
            (!('ga' in intent.jeongsi) || intent.jeongsi.ga is map) &&
            (!('na' in intent.jeongsi) || intent.jeongsi.na is map) &&
            (!('da' in intent.jeongsi) || intent.jeongsi.da is map)
          );
        }

        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
                              && validIntent(request.resource.data.intent);
      }

      /* entitlements — 결제 권한. 클라 write 절대 금지 (Admin SDK only). */
      match /entitlements/{entitlementId} {
        allow read: if isOwner(uid) || isMaster();
        allow write: if false;
      }

      /* 사용량 카운터(쿼터·rate-limit 캐시). 클라 read만, 갱신은 서버. */
      match /usage/{usageId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    /* ═══════════════════════════════════════════════════════════════════
       orders — 결제 주문
       사용자는 본인 주문 read만. write는 Admin SDK only.
       paymentKey 노출 차단을 위해 read 시 필드 제한이 필요하면
       별도 뷰 컬렉션(orders_public/{orderId})으로 분리하는 패턴 검토.
       ═══════════════════════════════════════════════════════════════════ */

    match /orders/{orderId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false; // Admin SDK 트랜잭션만 (api/payment/confirm)
    }

    /* ═══════════════════════════════════════════════════════════════════
       admins — 운영자 명단
       master만 read. write는 콘솔에서 직접.
       ═══════════════════════════════════════════════════════════════════ */

    match /admins/{uid} {
      allow read: if isMaster();
      allow write: if false;
    }

    /* ═══════════════════════════════════════════════════════════════════
       monitoring — 운영 메트릭 (counselor sanitize 발동률 등)
       클라 read/write 전부 차단. 서버(Admin SDK)만 write, 운영자만 read.
       admin 대시보드는 별도 백오피스에서 Admin SDK 로 조회.
       ═══════════════════════════════════════════════════════════════════ */

    match /monitoring/{doc=**} {
      allow read: if isMaster();
      allow write: if false;
    }

    /* ═══════════════════════════════════════════════════════════════════
       기본 deny
       ═══════════════════════════════════════════════════════════════════ */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
