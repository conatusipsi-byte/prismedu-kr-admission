{
  "name": "conatusipsi (Next.js + Firebase)",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installGradle": false,
      "installMaven": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "npm ci && npx playwright install --with-deps chromium && npm install -g firebase-tools",
  "forwardPorts": [9002, 4000, 4400, 8080, 9099, 9199],
  "portsAttributes": {
    "9002": { "label": "Next.js dev", "onAutoForward": "notify" },
    "4000": { "label": "Firebase Emulator UI", "onAutoForward": "silent" },
    "4400": { "label": "Firebase Emulator Hub", "onAutoForward": "silent" },
    "8080": { "label": "Firestore Emulator", "onAutoForward": "silent" },
    "9099": { "label": "Auth Emulator", "onAutoForward": "silent" },
    "9199": { "label": "Storage Emulator", "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-playwright.playwright",
        "vitest.explorer",
        "toba.vsfire",
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  },
  "remoteEnv": {
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  }
}
