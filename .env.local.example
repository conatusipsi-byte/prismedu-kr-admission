# conatusipsi 환경변수 — .env.local로 복사 후 실제 값 입력
# Production 배포는 호스팅 환경(Vercel/Firebase Hosting 등)의 secret manager 사용

# ─── Firebase Emulator (개발 전용) ───
# true 시 lib/firebase.ts 가 Firestore:8080, Auth:9099 로 자동 연결.
# production 환경에서는 이 변수가 true 여도 무시됨 (안전 가드).
NEXT_PUBLIC_USE_EMULATOR=false
# Emulator 시드 데이터 로드 시 사용 (서버 측 init-collections.ts):
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# ─── Anthropic Claude API ───
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Firebase 클라이언트 SDK (NEXT_PUBLIC_*는 브라우저에 노출됨) ───
# Firebase Console → 프로젝트 설정 → 일반 → 내 앱
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=prism-app-3ab7d
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin SDK (서버 전용 — 결제/카카오/API 인증) ───
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
FIREBASE_ADMIN_PROJECT_ID=prism-app-3ab7d
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-...@prism-app-3ab7d.iam.gserviceaccount.com
# private key는 한 줄에 작성, 개행은 \n 이스케이프
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Toss Payments (결제) ───
# https://app.tosspayments.com/
TOSS_SECRET_KEY=test_sk_...
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_gck_...

# ─── 카카오 OAuth (선택) ───
# https://developers.kakao.com/console/app
NEXT_PUBLIC_KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ─── Google Analytics (선택) ───
# 값이 없으면 Analytics 컴포넌트는 consent 배너까지 렌더하지 않음.
NEXT_PUBLIC_GA_ID=

# ─── Sentry (선택, 에러 트래킹) ───
# DSN 비어 있으면 sentry.client/server/edge.config.ts에서 init이 no-op으로 처리됨.
# https://sentry.io/settings/[org]/projects/[project]/keys/
NEXT_PUBLIC_SENTRY_DSN=
# 소스맵 업로드용 (CI 빌드 시에만 필요; 로컬은 비워둬도 됨)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── 마스터 계정 (운영진 — 모든 plan 한도 우회) ───
# 서버 전용. 쉼표 구분 이메일 목록. 빈 값이면 마스터 없음.
# 이전 NEXT_PUBLIC_MASTER_EMAILS 지양 — 클라이언트 번들에 이메일 목록이 노출됨.
MASTER_EMAILS=admin@example.com,owner@example.com

# ─── 사업자 정보 (전자상거래법 통신판매업 표시 의무) ───
# 출시 전 사업자등록 + 통신판매업 신고 후 입력. 미입력 시 footer는 placeholder 노출.
# 핵심 4개 필드(NAME/REPRESENTATIVE/REGISTRATION_NUMBER/TELECOM_NUMBER)가 모두 채워져야
# 실제 정보로 간주됨. NEXT_PUBLIC_ prefix는 클라이언트 노출 footer에서 읽기 위한 것이며,
# 사업자 정보 자체가 공개 의무 정보라 보안 이슈 없음.
NEXT_PUBLIC_BIZ_NAME=
NEXT_PUBLIC_BIZ_REPRESENTATIVE=
NEXT_PUBLIC_BIZ_REGISTRATION_NUMBER=
NEXT_PUBLIC_BIZ_TELECOM_NUMBER=
NEXT_PUBLIC_BIZ_ADDRESS=
NEXT_PUBLIC_BIZ_EMAIL=
NEXT_PUBLIC_BIZ_PHONE=
NEXT_PUBLIC_BIZ_PRIVACY_OFFICER=
NEXT_PUBLIC_BIZ_PRIVACY_OFFICER_EMAIL=

# ─── 앱 스토어 URL (출시 후 입력) ───
# /pricing의 일반 유저 CTA가 이 URL로 다운로드 유도. 빈 값이면 "#" fallback.
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=
